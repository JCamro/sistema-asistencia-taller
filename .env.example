# Django Settings
SECRET_KEY=your-super-secret-key-here-change-in-production
DEBUG=False

# Database (Railway provides DATABASE_URL automatically)
# Example for local development:
# DATABASE_URL=postgres://user:password@localhost:5432/dbname

# Allowed Hosts (comma-separated, no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.vercel.app

# CORS Settings (comma-separated origins)
CORS_ALLOWED_ORIGINS=https://tu-proyecto.vercel.app,http://localhost:5173

# Site URL (for absolute URLs in emails, etc.)
SITE_URL=https://tu-proyecto.vercel.app