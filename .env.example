# ===========================================
# VARIABLES DE ENTORNO PARA PRODUCCIÓN
# ===========================================
# Copia este archivo como .env y completa los valores

# -------------------------------------------
# BACKEND (Django) - Railway
# -------------------------------------------

# IMPORTANTE: Genera una clave segura:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-super-secret-key-here

# False en producción ( habilita whitenoise, deshabilita debug)
DEBUG=False

# Tus dominios separados por coma:
# - localhost,127.0.0.1 (desarrollo)
# - tu-app.up.railway.app (Railway)
ALLOWED_HOSTS=localhost,127.0.0.1,your-railway-subdomain.up.railway.app

# Frontend Vercel domains:
# - http://localhost:5173 (desarrollo)
# - https://tu-app.vercel.app (producción)
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tu-app.vercel.app

# Railway proporciona DATABASE_URL automáticamente
# No necesitas definirlo manualmente
# DATABASE_URL=postgres://user:pass@host:port/db

# -------------------------------------------
# FRONTEND (Vite) - Vercel
# -------------------------------------------

# URL del backend (sin trailing slash)
# Desarrollo: http://localhost:8000
# Producción: https://your-railway-subdomain.up.railway.app
VITE_API_URL=https://your-railway-subdomain.up.railway.app

# -----------------------------------
# CONFIGURACIÓN SUGERIDA
# -----------------------------------

# Railway:
# 1. Crear proyecto nuevo
# 2. Linkear repositorio GitHub
# 3. Agregar variables en Settings > Variables:
#    - SECRET_KEY = (generar)
#    - DEBUG = False
#    - ALLOWED_HOSTS = tu-app.up.railway.app
#    - CORS_ALLOWED_ORIGINS = https://tu-app.vercel.app

# Vercel:
# 1. Importar repositorio
# 2. Framework: Vite
# 3. Build: npm run build
# 4. Output: dist
# 5. Variables en Settings > Environment Variables:
#    - VITE_API_URL = https://tu-app.up.railway.app